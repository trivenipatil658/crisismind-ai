# Backend environment variables for local development and deployment
# Do NOT commit your actual .env file to GitHub.

# CORS configuration
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# LLM configuration (optional)
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# SQLite database file path for local/hackathon use
# In cloud deployment, this file is stored on the Render instance filesystem.
# For production, migrate to PostgreSQL and use a DATABASE_URL instead.
DATABASE_FILE=crisismind.db

# Optional Groq API support
# GROQ_API_KEY=
# GROQ_API_URL=https://api.groq.ai/v1

# Email alert configuration (only if you want email alerts)
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# RECIPIENT_EMAIL=
